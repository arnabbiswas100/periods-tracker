# Lumina Flow — Environment Variables
# Copy this file to .env.local for development
# Set these in Render → Environment Variables for production

# ── Supabase (free tier at supabase.com) ──────────────────────────
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings → API
# 3. Copy the URL and the anon/public key

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON=your-anon-key-here

# ── Web Push VAPID (for background push notifications) ────────────
# Generate a VAPID key pair by running:
#   npx web-push generate-vapid-keys
# Then paste the PUBLIC key here (keep the PRIVATE key on your server/edge function)

VITE_VAPID_PUBLIC=your-vapid-public-key-here
